#!/bin/bash

# jssh-gum: SSH 서버 관리자 (gum 기반)
# 간결하고 예쁜 터미널 UI로 SSH 서버를 관리합니다

set -e

# 스크립트 디렉토리
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIBS_DIR="$SCRIPT_DIR/libs"
CONFIG_FILE="$SCRIPT_DIR/default.conf"
SERVERS_FILE="$SCRIPT_DIR/servers.list"

# 모듈 로드
if [[ -f "$LIBS_DIR/installer.sh" ]]; then
    source "$LIBS_DIR/installer.sh"
fi

if [[ -f "$LIBS_DIR/ui_utils.sh" ]]; then
    source "$LIBS_DIR/ui_utils.sh"
fi

if [[ -f "$LIBS_DIR/ssh_utils.sh" ]]; then
    source "$LIBS_DIR/ssh_utils.sh"
fi

# 초기 설정 검사 및 자동 설치
initial_setup() {
    echo "» jssh-gum 초기화 중..."
    echo ""

    # python3 없으면 안내 후 종료 (설치 불가)
    if ! command -v python3 &> /dev/null; then
        echo "✗ python3가 필요합니다."
        echo "   macOS: brew install python3"
        echo "   Linux: sudo apt-get install python3"
        exit 1
    fi

    # gum이 없으면 설치 마법사 실행
    if ! command -v gum &> /dev/null; then
        echo "필수 도구 설치가 필요합니다."
        echo ""
        if [[ -f "$LIBS_DIR/installer.sh" ]]; then
            auto_install_wizard
            local install_result=$?
            if [[ $install_result -ne 0 ]]; then
                echo ""
                echo "✗ 초기 설정에 실패했습니다."
                echo "   gum을 수동으로 설치한 후 다시 시도해주세요."
                echo ""
                echo "설치 방법:"
                echo "  macOS: brew install gum"
                echo "  Linux: sudo snap install gum"
                echo "  또는: https://github.com/charmbracelet/gum/releases"
                exit 1
            fi
        else
            echo "✗ 설치 모듈을 찾을 수 없습니다."
            echo "   gum을 수동으로 설치해주세요."
            exit 1
        fi
    fi

    # fzf 없으면 자동 설치
    if ! command -v fzf &> /dev/null; then
        echo "fzf가 설치되지 않았습니다. (서버 목록 UI에 필요)"
        echo ""
        if [[ -f "$LIBS_DIR/installer.sh" ]]; then
            install_fzf
            if ! command -v fzf &> /dev/null; then
                echo "!  fzf 설치 실패 - 수동 설치: brew install fzf"
                sleep 2
            fi
        fi
    fi

    # 모듈 재로드 (설치 후)
    if [[ -f "$LIBS_DIR/ui_utils.sh" ]]; then
        source "$LIBS_DIR/ui_utils.sh"
    fi

    if [[ -f "$LIBS_DIR/ssh_utils.sh" ]]; then
        source "$LIBS_DIR/ssh_utils.sh"
    fi
}

# 설정 파일 로드
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    else
        show_warning "설정 파일을 찾을 수 없습니다: $CONFIG_FILE"
        create_default_config
    fi
}

# 기본 설정 파일 생성
create_default_config() {
    cat > "$CONFIG_FILE" << 'CONF_EOF'
# jssh-gum 기본 설정 파일
# SSH 연결을 위한 기본값들을 정의합니다

# 기본 SSH 포트
DEFAULT_PORT=22

# 기본 접속 계정
DEFAULT_USER="root"

# 기본 패스워드
DEFAULT_PASSWORD="password"

# 서버 목록 파일 경로
SERVERS_FILE="$(dirname "$0")/servers.list"

# Warp 터미널 완전 호환 모드 (exec 사용)
# true: exec로 셸 교체 (Warp 기능 완전 보존, 연결 후 스크립트 종료)
# false: 일반 모드 (연결 후 메뉴로 복귀)
WARP_COMPATIBLE_MODE="true"

# 설정 파일 버전
CONFIG_VERSION="1.1"
CONF_EOF
    show_success "기본 설정 파일을 생성했습니다."
}

# 서버 목록 파일 생성
create_servers_file() {
    if [[ ! -f "$SERVERS_FILE" ]]; then
        cat > "$SERVERS_FILE" << 'SERVERS_EOF'
# 서버 목록 파일
# 형식: 별칭|구분|hostname|ip|port|user|password
# 예제 (실제 사용시 수정하세요)
localhost|테스트|localhost|127.0.0.1|22|user|
SERVERS_EOF
        show_success "서버 목록 파일을 생성했습니다."
    fi
}

# SSH 키 생성 마법사
generate_ssh_key_wizard() {
    clear
    show_info "🔑 SSH 키 신규 생성"
    echo ""
    
    # 1. 파일 이름 입력
    echo "새로운 SSH 키 파일 이름을 입력하세요 (예: id_ed25519_new)"
    local key_name
    key_name=$(gum input --placeholder "파일 이름")
    [[ -z "$key_name" ]] && return 1

    # 2. 접속 ID 입력
    echo ""
    echo "SSH 접속 ID (코멘트)를 입력하세요 (예: my-server-key)"
    local key_comment
    key_comment=$(gum input --placeholder "접속 ID")
    [[ -z "$key_comment" ]] && key_comment="jssh-key"

    # 3. 경로 입력
    echo ""
    echo "저장할 경로를 입력하세요 (기본값: ~/.ssh)"
    local key_dir
    key_dir=$(gum input --placeholder "~/.ssh" --value "~/.ssh")
    [[ -z "$key_dir" ]] && key_dir="~/.ssh"
    
    # 경로 변환 (~ 확장)
    local eval_dir="${key_dir/#\~/$HOME}"
    
    # 디렉토리 생성
    if [[ ! -d "$eval_dir" ]]; then
        echo ""
        show_info "디렉토리가 존재하지 않습니다. 생성합니다: $eval_dir"
        mkdir -p "$eval_dir"
    fi
    
    local full_path="$eval_dir/$key_name"
    
    # 파일 존재 여부 확인
    if [[ -f "$full_path" ]]; then
        echo ""
        show_error "경고: 파일이 이미 존재합니다 ($full_path)"
        sleep 2
        return 1
    fi
    
    echo ""
    show_info "키를 생성하는 중입니다..."
    # 키 생성 실행
    if ssh-keygen -t ed25519 -C "$key_comment" -f "$full_path" -N ""; then
        echo ""
        show_success "SSH 키가 성공적으로 생성되었습니다!"
        # 변환 전의 경로 문자열(~ 유지)로 리턴하여 폼에 예쁘게 보이도록 함
        echo "$key_dir/$key_name"
        sleep 2
        return 0
    else
        echo ""
        show_error "키 생성에 실패했습니다."
        sleep 2
        return 1
    fi
}

# 서버 목록 보기 (fzf 기반 테이블 + 실시간 검색 + footer 메뉴)
list_servers() {
    local FOOTER='  [Enter] 접속   [^A] 추가   [^D] 삭제   [^E] 편집   [^O] 순서변경   [^S] 설정   [ESC] 종료'

    while true; do
        clear

        if [[ ! -f "$SERVERS_FILE" ]] || [[ ! -s "$SERVERS_FILE" ]]; then
            show_error "등록된 서버가 없습니다."
            echo ""
            if confirm_dialog "서버를 추가하시겠습니까?"; then
                add_server
                continue
            fi
            return
        fi

        # fzf 설치 여부 확인
        if ! command -v fzf &> /dev/null; then
            show_error "fzf가 필요합니다. brew install fzf 로 설치하세요."
            wait_for_input
            return
        fi

        # 서버 데이터 수집 (별칭 배열 + raw 행 배열)
        local all_aliases=()
        local raw_lines=()

        while IFS='|' read -r alias category hostname ip port user password ssh_key; do
            [[ "$alias" =~ ^# ]] || [[ -z "$alias" ]] && continue
            all_aliases+=("$alias")
            local display_hostname="${hostname:-"-"}"
            local display_user="${user:-${DEFAULT_USER:-root}}"
            local display_key="${ssh_key:-"-"}"
            raw_lines+=("${alias}	${category}	${display_hostname}	${ip}	${port}	${display_user}	${display_key}")
        done < "$SERVERS_FILE"

        if [[ ${#all_aliases[@]} -eq 0 ]]; then
            show_error "연결할 서버가 없습니다."
            wait_for_input
            return
        fi

        # Python3로 헤더/구분선/fzf 입력 데이터 한 번에 생성
        local py_out
        py_out=$(python3 - <<'PYEOF' "${raw_lines[@]}"
import sys, unicodedata

MAX = {"alias": 26, "cat": 6, "host": 22, "ip": 18, "port": 4, "user": 10, "key": 16}

def dw(s):
    w = 0
    for c in s:
        ea = unicodedata.east_asian_width(c)
        w += 2 if ea in ("W", "F") else 1
    return w

def pad(s, width):
    cur = dw(s)
    if cur > width:
        out, c = "", 0
        for ch in s:
            ea = unicodedata.east_asian_width(ch)
            cw = 2 if ea in ("W", "F") else 1
            if c + cw + 1 <= width:
                out += ch; c += cw
            else:
                break
        out += "…"; c += 1
        return out + " " * max(0, width - c)
    return s + " " * (width - cur)

rows = []
for line in sys.argv[1:]:
    parts = line.split("\t", 6)
    while len(parts) < 7:
        parts.append("")
    rows.append(parts)

n = len(rows)
W_no   = max(3, len(str(n)))
W_al   = max(4,  min(MAX["alias"], max((dw(r[0]) for r in rows), default=4)))
W_cat  = max(4,  min(MAX["cat"],   max((dw(r[1]) for r in rows), default=4)))
W_host = max(6,  min(MAX["host"],  max((dw(r[2]) for r in rows), default=6)))
W_ip   = max(9,  min(MAX["ip"],    max((dw(r[3]) if r[3] and r[3] != "-" else dw("(ssh cfg)") for r in rows), default=9)))
W_port = max(4,  min(MAX["port"],  max((dw(r[4]) for r in rows), default=4)))
W_user = max(6,  min(MAX["user"],  max((dw(r[5]) for r in rows), default=6)))
W_key  = max(6,  min(MAX["key"],   max((dw(r[6]) if len(r)>6 else 1 for r in rows), default=6)))

def sep(w): return "─" * w

hdr = (" " + pad("No.", W_no) + " │ " + pad("별칭", W_al) + " │ " +
       pad("구분", W_cat) + " │ " + pad("호스트명", W_host) + " │ " +
       pad("IP주소", W_ip) + " │ " + pad("포트", W_port) + " │ " +
       pad("사용자", W_user) + " │ " + pad("SSH키", W_key))
sep_row = (sep(W_no+2) + "┼" + sep(W_al+2) + "┼" + sep(W_cat+2) + "┼" +
           sep(W_host+2) + "┼" + sep(W_ip+2) + "┼" + sep(W_port+2) + "┼" +
           sep(W_user+2) + "┼" + sep(W_key+2))

print("HDR:" + hdr)
print("SEP:" + sep_row)
for i, r in enumerate(rows, 1):
    disp_ip = r[3] if r[3] and r[3] != "-" else "(ssh cfg)"
    disp_key = r[6] if len(r)>6 and r[6] else "-"
    row = (" " + pad(str(i), W_no) + " │ " + pad(r[0], W_al) + " │ " +
           pad(r[1], W_cat) + " │ " + pad(r[2], W_host) + " │ " +
           pad(disp_ip, W_ip) + " │ " + pad(r[4], W_port) + " │ " +
           pad(r[5], W_user) + " │ " + pad(disp_key, W_key))
    print(str(i) + "§" + row)
PYEOF
)

        if [[ -z "$py_out" ]]; then
            show_error "서버 목록 생성에 실패했습니다. (python3 필요)"
            wait_for_input
            return
        fi

        local HDR_ROW SEP_ROW fzf_input
        HDR_ROW=$(printf '%s\n' "$py_out" | grep '^HDR:' | head -1)
        HDR_ROW="${HDR_ROW#HDR:}"
        SEP_ROW=$(printf '%s\n' "$py_out" | grep '^SEP:' | head -1)
        SEP_ROW="${SEP_ROW#SEP:}"
        fzf_input=$(printf '%s\n' "$py_out" | grep -v '^HDR:' | grep -v '^SEP:')

        # fzf 실행
        local selected
        selected=$(
            printf '%s\n' "$fzf_input" \
            | fzf \
                --delimiter='§' \
                --with-nth='2..' \
                --header="${HDR_ROW}"$'\n'"${SEP_ROW}" \
                --header-lines=0 \
                --footer="$FOOTER" \
                --expect='ctrl-a,ctrl-d,ctrl-e,ctrl-o,ctrl-s' \
                --prompt='  검색: ' \
                --pointer='▶' \
                --layout=reverse \
                --border=rounded \
                --height=~100% \
                --color='header:bold:38,prompt:46,pointer:46,hl:46,hl+:46,bg+:236,fg+:255,border:238,footer:241' \
                --cycle \
                --bind='esc:abort,left:page-up,right:page-down' \
                2>/dev/null \
            || true
        )

        # ESC 또는 Ctrl-C → 종료
        [[ -z "$selected" ]] && return

        local key item
        key=$(printf '%s' "$selected" | head -1)
        item=$(printf '%s' "$selected" | sed -n '2p')

        case "$key" in
            ctrl-a)
                add_server
                ;;
            ctrl-d)
                if [[ -n "$item" ]]; then
                    local sel_idx
                    sel_idx=$(printf '%s' "$item" | cut -d'§' -f1 | tr -d ' ')
                    if [[ "$sel_idx" =~ ^[0-9]+$ ]]; then
                        local del_alias="${all_aliases[$((sel_idx - 1))]}"
                        echo ""
                        if confirm_dialog "서버 '${del_alias}'를 삭제하시겠습니까?"; then
                            awk -F'|' -v a="$del_alias" '$1 != a' "$SERVERS_FILE" > "${SERVERS_FILE}.tmp" \
                                && mv "${SERVERS_FILE}.tmp" "$SERVERS_FILE"
                            show_success "'${del_alias}' 삭제되었습니다."
                            sleep 1
                        fi
                    fi
                fi
                ;;
            ctrl-e)
                if [[ -n "$item" ]]; then
                    local sel_idx
                    sel_idx=$(printf '%s' "$item" | cut -d'§' -f1 | tr -d ' ')
                    if [[ "$sel_idx" =~ ^[0-9]+$ ]]; then
                        edit_server "${all_aliases[$((sel_idx - 1))]}"
                    fi
                fi
                ;;
            ctrl-o)
                reorder_servers
                ;;
            ctrl-s)
                settings_menu
                ;;
            "")
                # Enter: 접속
                if [[ -n "$item" ]]; then
                    local sel_idx
                    sel_idx=$(printf '%s' "$item" | cut -d'§' -f1 | tr -d ' ')
                    if [[ "$sel_idx" =~ ^[0-9]+$ ]]; then
                        local arr_idx=$((sel_idx - 1))
                        if [[ $arr_idx -ge 0 && $arr_idx -lt ${#all_aliases[@]} ]]; then
                            connect_to_server "${all_aliases[$arr_idx]}"
                        fi
                    fi
                fi
                ;;
        esac
    done
}

# 검색 및 필터링 함수
search_and_filter_servers() {
    local server_data="$1"
    local servers_array_name="$2"
    
    clear
    show_info "? 서버 검색"
    echo ""
    echo "검색 옵션을 생성하는 중..."
    
    # 검색 가능한 서버 목록 생성
    local search_options=""
    while IFS='|' read -r num alias category hostname ip port user; do
        [[ -z "$num" || "$num" == "No." ]] && continue
        search_options+="$num. $alias [$category] $user@$ip:$port ($hostname)\n"
    done <<< "$(echo -e "$server_data" | tail -n +2)"
    
    echo ""
    echo "→ 서버명, 구분, IP, 호스트명으로 실시간 검색 가능"
    echo "→ ESC를 눌러 서버 목록으로 돌아가기"
    echo ""
    
    # gum filter로 실시간 검색
    local selected_line
    selected_line=$(echo -e "$search_options" | gum filter \
        --placeholder "? 검색어를 입력하세요 (서버명/구분/IP/호스트명)..." \
        --height 15 \
        --no-limit \
        --indicator="→ " \
        --match.foreground=46 \
        --text.foreground=255 || echo "")
    
    if [[ -n "$selected_line" ]]; then
        # 선택된 라인에서 번호 추출
        local selected_number=$(echo "$selected_line" | cut -d'.' -f1)
        
        if [[ "$selected_number" =~ ^[0-9]+$ ]]; then
            local array_index=$((selected_number - 1))
            # servers 배열의 크기 확인 (동적으로)
            local servers_count=$(eval "echo \${#$servers_array_name[@]}")
            if [[ $array_index -ge 0 ]] && [[ $array_index -lt $servers_count ]]; then
                local selected_alias=$(eval "echo \${$servers_array_name[$array_index]}")
                connect_to_server "$selected_alias"
                return 0  # 서버가 선택됨
            fi
        fi
    fi
    
    return 1  # 검색에서 돌아감
}

# 서버 추가
add_server() {
    local INFO_MSG="호스트명이 ~/.ssh/config 에 등록된 경우 IP 주소, 포트, 사용자, 패스워드는 생략할 수 있습니다.\n인증방식 필드에서는 좌우 방향키나 Space를 눌러 값을 변경하세요."

    local form_out form_exit
    local cur_alias="" cur_category="" cur_hostname="" cur_ip="" cur_port="$DEFAULT_PORT" cur_user="$DEFAULT_USER" cur_auth="패스워드" cur_password="" cur_ssh_key=""

    while true; do
        form_out=$(python3 "$LIBS_DIR/form.py" \
            --title "서버 추가" \
            --info  "$INFO_MSG" \
            "별칭"    "$cur_alias"    "0" \
            "구분"    "$cur_category" "0" \
            "호스트명" "$cur_hostname" "0" \
            "IP 주소" "$cur_ip"      "0" \
            "포트"    "$cur_port"    "0" \
            "사용자"  "$cur_user"    "0" \
            "인증방식" "$cur_auth"    "choice:패스워드,SSH 키" \
            "패스워드" "$cur_password" "1" \
            "SSH키"   "$cur_ssh_key" "0") && form_exit=0 || form_exit=$?

        if [[ "$form_exit" -eq 1 ]]; then
            return 0   # ESC → 목록으로 복귀
        fi

        # 값 갱신 (저장 전이나 마법사 이동 전 현재 값 유지)
        cur_alias=$(    printf '%s\n' "$form_out" | sed -n '1p')
        cur_category=$( printf '%s\n' "$form_out" | sed -n '2p')
        cur_hostname=$( printf '%s\n' "$form_out" | sed -n '3p')
        cur_ip=$(       printf '%s\n' "$form_out" | sed -n '4p')
        cur_port=$(     printf '%s\n' "$form_out" | sed -n '5p')
        cur_user=$(     printf '%s\n' "$form_out" | sed -n '6p')
        cur_auth=$(     printf '%s\n' "$form_out" | sed -n '7p')
        cur_password=$( printf '%s\n' "$form_out" | sed -n '8p')
        cur_ssh_key=$(  printf '%s\n' "$form_out" | sed -n '9p')

        if [[ "$cur_auth" == "패스워드" ]]; then
            cur_ssh_key=""
        elif [[ "$cur_auth" == "SSH 키" ]]; then
            cur_password=""
        fi

        if [[ "$form_exit" -eq 7 ]]; then
            # Ctrl-G: 키 생성 마법사 실행
            local generated_key wizard_exit
            generated_key=$(generate_ssh_key_wizard) && wizard_exit=0 || wizard_exit=$?
            
            if [[ $wizard_exit -eq 0 && -n "$generated_key" ]]; then
                cur_ssh_key=$(printf '%s\n' "$generated_key" | tail -n 1)
            fi
            continue # 폼 다시 열기
        fi

        if [[ "$form_exit" -eq 0 ]]; then
            break # Enter -> 저장
        fi
    done

    # 별칭 필수 확인
    if [[ -z "$cur_alias" ]]; then
        show_error "별칭은 필수입니다."
        sleep 1
        return
    fi

    # 중복 확인
    if awk -F'|' -v a="$cur_alias" '$1 == a { exit 0 } END { exit 1 }' "$SERVERS_FILE" 2>/dev/null; then
        show_error "이미 존재하는 별칭입니다: $cur_alias"
        sleep 1
        return
    fi

    # 기본값 적용
    [[ -z "$cur_port" ]]     && cur_port="$DEFAULT_PORT"
    [[ -z "$cur_user" ]]     && cur_user="$DEFAULT_USER"
    [[ -z "$cur_password" ]] && cur_password="$DEFAULT_PASSWORD"

    echo "$cur_alias|$cur_category|$cur_hostname|$cur_ip|$cur_port|$cur_user|$cur_password|$cur_ssh_key" >> "$SERVERS_FILE"
    show_success "'$cur_alias' 서버가 추가되었습니다."
    sleep 1
}

# 서버 순서 변경
reorder_servers() {
    if [[ ! -f "$SERVERS_FILE" ]] || [[ ! -s "$SERVERS_FILE" ]]; then
        show_error "등록된 서버가 없습니다."
        sleep 1
        return
    fi

    # 현재 순서로 별칭 배열 읽기
    local aliases=()
    while IFS='|' read -r alias rest; do
        [[ "$alias" =~ ^# ]] || [[ -z "$alias" ]] && continue
        aliases+=("$alias")
    done < "$SERVERS_FILE"

    if [[ ${#aliases[@]} -lt 2 ]]; then
        show_error "순서를 변경하려면 서버가 2개 이상 필요합니다."
        sleep 1
        return
    fi

    # Python3 curses 기반 순서 변경 UI
    local new_order
    new_order=$(python3 - "${aliases[@]}" <<'PYEOF'
import curses, os, sys

items   = list(sys.argv[1:])
current = 0
grabbed = False   # Space로 잡은 상태

def run(stdscr):
    global current, grabbed
    curses.curs_set(0)
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN,  -1)                   # 제목
    curses.init_pair(2, curses.COLOR_BLACK, curses.COLOR_WHITE)   # 커서 행 (일반)
    curses.init_pair(3, curses.COLOR_YELLOW, -1)                  # 힌트 / 구분선
    curses.init_pair(4, curses.COLOR_BLACK, curses.COLOR_YELLOW)  # 잡힌(grabbed) 행

    while True:
        h, w = stdscr.getmaxyx()
        stdscr.erase()

        try:
            stdscr.addstr(1, 2, "  서버 순서 변경  ",
                          curses.color_pair(1) | curses.A_BOLD)
            stdscr.addstr(2, 2, "─" * min(50, w - 4), curses.color_pair(3))
        except curses.error:
            pass

        for i, name in enumerate(items):
            y = 3 + i
            if y >= h - 4:
                break
            if grabbed and i == current:
                marker = " ↕ "
                attr   = curses.color_pair(4) | curses.A_BOLD
            elif i == current:
                marker = " ▶ "
                attr   = curses.color_pair(2) | curses.A_BOLD
            else:
                marker = "   "
                attr   = 0
            try:
                stdscr.addstr(y, 2, (marker + name)[:w - 3], attr)
            except curses.error:
                pass

        footer_y = 3 + len(items) + 1
        if grabbed:
            hint = "↑↓: 위치 이동   Space: 놓기   ESC: 취소"
        else:
            hint = "↑↓: 커서 이동   Space: 잡기   Enter: 저장   ESC: 취소"
        try:
            stdscr.addstr(footer_y, 2, "─" * min(50, w - 4), curses.color_pair(3))
            stdscr.addstr(footer_y + 1, 2, hint, curses.color_pair(3))
        except curses.error:
            pass

        stdscr.refresh()

        try:
            ch = stdscr.get_wch()
        except Exception:
            continue

        code = ord(ch) if isinstance(ch, str) else ch

        if code == 27:          # ESC
            if grabbed:
                grabbed = False  # 잡은 상태 해제만
            else:
                return None
        elif code in (10, 13):  # Enter → 저장
            grabbed = False
            return items
        elif code == 32:        # Space → 잡기/놓기 토글
            grabbed = not grabbed
        elif code == curses.KEY_UP:
            if grabbed and current > 0:
                items[current], items[current - 1] = items[current - 1], items[current]
                current -= 1
            elif not grabbed:
                current = max(0, current - 1)
        elif code == curses.KEY_DOWN:
            if grabbed and current < len(items) - 1:
                items[current], items[current + 1] = items[current + 1], items[current]
                current += 1
            elif not grabbed:
                current = min(len(items) - 1, current + 1)

tty_fd  = os.open("/dev/tty", os.O_RDWR)
old_in  = os.dup(0)
old_out = os.dup(1)
os.dup2(tty_fd, 0)
os.dup2(tty_fd, 1)
os.close(tty_fd)

result = curses.wrapper(run)

os.dup2(old_out, 1); os.close(old_out)
os.dup2(old_in,  0); os.close(old_in)

if result is None:
    sys.exit(1)
for name in result:
    print(name)
PYEOF
    ) && true || { return 0; }   # ESC → 복귀

    if [[ -z "$new_order" ]]; then
        return 0
    fi

    # 새 순서로 servers.list 재작성
    # 1) 새 순서 별칭 배열
    local ordered=()
    while IFS= read -r line; do
        [[ -n "$line" ]] && ordered+=("$line")
    done <<< "$new_order"

    # 2) 원본 파일에서 각 별칭 행을 새 순서대로 출력
    local tmp="${SERVERS_FILE}.tmp"
    : > "$tmp"
    for a in "${ordered[@]}"; do
        awk -F'|' -v al="$a" '$1 == al { print; exit }' "$SERVERS_FILE" >> "$tmp"
    done
    # 3) 주석/빈 행 보존 (맨 앞에)
    mv "$tmp" "$SERVERS_FILE"

    show_success "순서가 저장되었습니다."
    sleep 1
}

# 서버 편집
edit_server() {
    local alias="$1"

    local server_info
    server_info=$(awk -F'|' -v a="$alias" '$1 == a { print; exit }' "$SERVERS_FILE")

    if [[ -z "$server_info" ]]; then
        show_error "서버를 찾을 수 없습니다: $alias"
        sleep 1
        return
    fi

    local cur_alias cur_category cur_hostname cur_ip cur_port cur_user cur_password cur_ssh_key
    IFS='|' read -r cur_alias cur_category cur_hostname cur_ip cur_port cur_user cur_password cur_ssh_key \
        <<< "$server_info"

    local original_alias="$cur_alias" # 변경 감지를 위해 원본 백업
    local form_out form_exit
    local INFO_MSG="호스트명이 ~/.ssh/config 에 등록된 경우 IP 주소, 포트, 사용자, 패스워드는 생략할 수 있습니다.\n인증방식 필드에서는 좌우 방향키나 Space를 눌러 값을 변경하세요."

    local cur_auth="패스워드"
    if [[ -n "$cur_ssh_key" ]]; then
        cur_auth="SSH 키"
    fi

    while true; do
        form_out=$(python3 "$LIBS_DIR/form.py" \
            --title "서버 편집" \
            --info  "$INFO_MSG" \
            "별칭"    "$cur_alias"    "0" \
            "구분"    "$cur_category" "0" \
            "호스트명" "$cur_hostname" "0" \
            "IP 주소" "$cur_ip"      "0" \
            "포트"    "$cur_port"    "0" \
            "사용자"  "$cur_user"    "0" \
            "인증방식" "$cur_auth"    "choice:패스워드,SSH 키" \
            "패스워드" "$cur_password" "1" \
            "SSH키"   "$cur_ssh_key" "0") && form_exit=0 || form_exit=$?

        if [[ "$form_exit" -eq 1 ]]; then
            return 0   # ESC → 목록으로 복귀
        fi

        # 폼 데이터 갱신
        cur_alias=$(    printf '%s\n' "$form_out" | sed -n '1p')
        cur_category=$( printf '%s\n' "$form_out" | sed -n '2p')
        cur_hostname=$( printf '%s\n' "$form_out" | sed -n '3p')
        cur_ip=$(       printf '%s\n' "$form_out" | sed -n '4p')
        cur_port=$(     printf '%s\n' "$form_out" | sed -n '5p')
        cur_user=$(     printf '%s\n' "$form_out" | sed -n '6p')
        cur_auth=$(     printf '%s\n' "$form_out" | sed -n '7p')
        cur_password=$( printf '%s\n' "$form_out" | sed -n '8p')
        cur_ssh_key=$(  printf '%s\n' "$form_out" | sed -n '9p')

        if [[ "$cur_auth" == "패스워드" ]]; then
            cur_ssh_key=""
        elif [[ "$cur_auth" == "SSH 키" ]]; then
            cur_password=""
        fi

        if [[ "$form_exit" -eq 7 ]]; then
            # Ctrl-G: 키 생성 마법사 실행
            local generated_key wizard_exit
            generated_key=$(generate_ssh_key_wizard) && wizard_exit=0 || wizard_exit=$?
            
            if [[ $wizard_exit -eq 0 && -n "$generated_key" ]]; then
                cur_ssh_key=$(printf '%s\n' "$generated_key" | tail -n 1)
                cur_auth="SSH 키"
            fi
            continue # 폼 다시 열기
        fi

        if [[ "$form_exit" -eq 0 ]]; then
            break # Enter -> 저장
        fi
    done

    [[ -z "$cur_alias" ]]   && cur_alias="$original_alias"
    [[ -z "$cur_port" ]]    && cur_port="$DEFAULT_PORT"

    # 별칭 변경 시 중복 확인
    if [[ "$cur_alias" != "$original_alias" ]]; then
        if awk -F'|' -v a="$cur_alias" '$1 == a { exit 0 } END { exit 1 }' "$SERVERS_FILE" 2>/dev/null; then
            show_error "이미 존재하는 별칭입니다: $cur_alias"
            sleep 1
            return
        fi
    fi

    # 파일 업데이트 (awk: 첫 번째 필드가 일치하는 행만 교체)
    awk -F'|' -v old="$original_alias" \
        -v new="${cur_alias}|${cur_category}|${cur_hostname}|${cur_ip}|${cur_port}|${cur_user}|${cur_password}|${cur_ssh_key}" \
        '$1 == old { print new; next } { print }' \
        "$SERVERS_FILE" > "${SERVERS_FILE}.tmp" \
        && mv "${SERVERS_FILE}.tmp" "$SERVERS_FILE"

    show_success "'${cur_alias}' 저장되었습니다."
    sleep 1
}

# 서버 검색
search_servers() {
    clear
    
    show_info "? 서버 검색"
    echo ""
    
    if [[ ! -f "$SERVERS_FILE" ]] || [[ ! -s "$SERVERS_FILE" ]]; then
        show_error "등록된 서버가 없습니다."
        wait_for_input
        return
    fi
    
    # 검색 가능한 서버 목록 생성
    local search_list=""
    local count=1
    
    while IFS='|' read -r alias category hostname ip port user password; do
        [[ "$alias" =~ ^# ]] || [[ -z "$alias" ]] && continue
        
        local display_hostname="${hostname:-"-"}"
        search_list+="$count. $alias ($category) [$display_hostname] - $ip:$port\n"
        ((count++))
    done < "$SERVERS_FILE"
    
    if [[ -z "$search_list" ]]; then
        show_error "검색할 서버가 없습니다."
        wait_for_input
        return
    fi
    
    echo "→ 서버명, 카테고리, IP, 호스트명으로 검색할 수 있습니다"
    echo ""
    
    # gum filter로 검색
    local selected
    selected=$(echo -e "$search_list" | gum filter \
        --placeholder "? 검색어를 입력하세요 (서버명/카테고리/IP/호스트명)..." \
        --height 20 \
        --no-limit \
        --indicator="→ " \
        --match.foreground=46 \
        --text.foreground=255 || echo "")
    
    if [[ -n "$selected" ]]; then
        # 선택된 항목에서 별칭 추출
        local alias=$(echo "$selected" | sed 's/^[0-9]*\. \([^ ]*\).*/\1/')
        connect_to_server "$alias"
    fi
}

# 서버 연결
connect_to_server() {
    local alias="$1"
    
    # 서버 정보 찾기
    server_info=$(grep "^$alias|" "$SERVERS_FILE" || echo "")
    
    if [[ -z "$server_info" ]]; then
        show_error "서버를 찾을 수 없습니다: $alias"
        wait_for_input
        return
    fi
    
    IFS='|' read -r found_alias category hostname ip port user password ssh_key <<< "$server_info"
    
    # SSH 연결 대상 결정: ip 비어있으면 hostname을 SSH config alias로 사용
    local ssh_target
    if [[ -n "$ip" && "$ip" != "-" ]]; then
        ssh_target="$ip"
    else
        ssh_target="$hostname"
    fi
    
    clear
    
    # 연결 명령 미리보기
    local ssh_cmd="ssh"
    if [[ -n "$ssh_key" ]]; then
        ssh_cmd="$ssh_cmd -i $ssh_key"
    fi
    if [[ -n "$port" && "$port" != "22" ]]; then
        ssh_cmd="$ssh_cmd -p $port"
    fi
    if [[ -n "$user" ]]; then
        ssh_cmd="$ssh_cmd $user@$ssh_target"
    else
        ssh_cmd="$ssh_cmd $ssh_target"
    fi
    
    # 서버 정보를 간단히 표시
    show_info "→ SSH 서버 연결"
    echo ""
    echo "서버: $found_alias ($category)"
    if [[ -n "$ip" && "$ip" != "-" ]]; then
        echo "주소: ${user:+$user@}$ssh_target:$port"
    else
        echo "주소: ${user:+$user@}$ssh_target  (SSH config)"
    fi
    if [[ -n "$ssh_key" ]]; then
        echo "SSH키: $ssh_key"
    fi
    echo "명령: $ssh_cmd"
    echo ""
    
    if confirm_dialog "이 서버에 연결하시겠습니까?"; then
        echo ""
        show_info "SSH 연결을 시작합니다..."
        echo "연결을 종료하려면 'exit' 명령을 사용하세요"
        echo ""
        
        # 잠시 대기
        sleep 1
        
        # SSH 연결 실행 (Warp 호환 모드 설정에 따라)
        if [[ "${WARP_COMPATIBLE_MODE:-true}" == "true" ]]; then
            # exec 모드: Warp 기능 완전 보존, 연결 후 스크립트 종료
            connect_ssh_exec "$user" "$ssh_target" "$port" "$password" "$DEFAULT_PASSWORD" "$ssh_key"
        else
            # 일반 모드: 연결 후 메뉴로 복귀
            connect_ssh "$user" "$ssh_target" "$port" "$password" "$DEFAULT_PASSWORD" "false" "$ssh_key"
        fi
        
        # 연결 종료 후
        echo ""
        show_info "· SSH 연결이 종료되었습니다."
        wait_for_input
    fi
}

